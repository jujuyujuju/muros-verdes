// 1. Configuración del origen de datos
datasource db {
  provider = "sqlite"
}

// 2. Generador del cliente
generator client {
  provider = "prisma-client-js"
}

// 3. Modelos
model Muro {
  id        String   @id @default(uuid())
  nombre    String
  ubicacion String
  plantas   Planta[]
}

model Planta {
  id          String  @id @default(uuid())
  nombre      String
  descripcion String
  riego       String
  enlaceWiki  String? 
  muroId      String
  muro        Muro    @relation(fields: [muroId], references: [id])
}